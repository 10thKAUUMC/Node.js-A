	"paths": {
		"/users/signup": {
			"post": {
				"operationId": "HandleUserSignUp",
				"responses": {
					"200": {
						"description": "회원가입 성공",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse_UserSignUpResponse_"
								},
								"examples": {
									"Example 1": {
										"value": {
											"resultType": "SUCCESS",
											"error": null,
											"data": {
												"userId": 1,
												"preferences": [
													"한식",
													"일식"
												]
											}
										}
									}
								}
							}
						}
					},
					"400": {
						"description": "잘못된 요청 (비밀번호 누락 등)",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiErrorResponse"
								},
								"examples": {
									"Example 1": {
										"value": {
											"resultType": "FAILED",
											"error": {
												"errorCode": "V001",
												"message": "비밀번호가 누락되었습니다."
											},
											"data": null
										}
									}
								}
							}
						}
					},
					"409": {
						"description": "중복된 이메일 에러",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiErrorResponse"
								},
								"examples": {
									"Example 1": {
										"value": {
											"resultType": "FAILED",
											"error": {
												"errorCode": "U001",
												"message": "이미 존재하는 이메일입니다."
											},
											"data": null
										}
									}
								}
							}
						}
					}
				},
				"description": "새로운 사용자를 등록합니다. (회원가입)",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"description": "회원가입에 필요한 사용자 정보 및 선호 카테고리",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UserSignUpRequest",
								"description": "회원가입에 필요한 사용자 정보 및 선호 카테고리"
							}
						}
					}
				}
			}
		},
		"/users/{userId}/reviews": {
			"get": {
				"operationId": "HandleListUserReviews",
				"responses": {
					"200": {
						"description": "리뷰 목록 조회 성공",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse_UserReviewListResponse_"
								},
								"examples": {
									"Example 1": {
										"value": {
											"resultType": "SUCCESS",
											"error": null,
											"data": {
												"reviews": [
													{
														"id": 10,
														"storeName": "맛있는 가게",
														"content": "정말 맛있어요!",
														"star": 5
													}
												],
												"cursor": 10
											}
										}
									}
								}
							}
						}
					}
				},
				"description": "특정 사용자가 작성한 리뷰 목록을 조회합니다. (커서 기반 페이지네이션)",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": [
					{
						"description": "조회할 사용자의 ID",
						"in": "path",
						"name": "userId",
						"required": true,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "페이지네이션 커서 (마지막 리뷰 ID)",
						"in": "query",
						"name": "cursor",
						"required": false,
						"schema": {
							"default": 0,
							"format": "double",
							"type": "number"
						}
					}
				]
			}
		},
