// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique(map: "email") @db.VarChar(255)
  name          String   @db.VarChar(100)
  gender        String   @db.VarChar(15)
  birth         DateTime @db.Date
  address       String   @db.VarChar(255)
  detailAddress String?  @map("detail_address") @db.VarChar(255)
  phoneNumber   String   @map("phone_number") @db.VarChar(15)

  userFavorCategories UserFavorCategory[]
  reviews             UserStoreReview[]
  userMission         UserMission[]

  @@map("user")
}

model FoodCategory {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  userFavorCategories UserFavorCategory[]

  @@map("food_category")
}

model UserFavorCategory {
  id             Int          @id @default(autoincrement())
  user           User         @relation(fields: [userId], references: [id])
  userId         Int          @map("user_id")
  foodCategory   FoodCategory @relation(fields: [foodCategoryId], references: [id])
  foodCategoryId Int          @map("food_category_id")

  @@index([foodCategoryId], map: "f_category_id")
  @@index([userId], map: "user_id")
  @@map("user_favor_category")
}

model UserStoreReview {
  id      Int    @id @default(autoincrement())
  content String @db.Text

  // 외래 키 필드 (DB 컬럼)
  //에서 where 절에 사용된 storeId와 일치해야 합니다.
  storeId Int @map("store_id")
  userId  Int @map("user_id")

  // 관계 설정 (Prisma Client에서 객체로 접근하기 위함)
  //의 select 로직에서 store와 user 정보를 가져오기 위해 필수입니다.
  store Store @relation(fields: [storeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("user_store_review") // 실제 DB 테이블명
}

// 관계된 모델 예시
model Store {
  id       Int               @id @default(autoincrement())
  name     String
  reviews  UserStoreReview[]
  missions Mission[]
}

model Mission {
  id          Int      @id @default(autoincrement())
  title       String   // 추가
  description String?  // 추가 (선택 사항일 경우 ? 유지)
  point       Int      @default(0) // 추가
  deadline    DateTime // 기존 필수 필드

  // 관계 설정
  storeId     Int           @map("store_id")
  store       Store         @relation(fields: [storeId], references: [id])
  userMission UserMission[]

  @@map("mission")
}

model UserMission {
  id        Int      @id @default(autoincrement())
  userId    Int // 어떤 유저가
  missionId Int // 어떤 미션을 하는가
  status    String // 상태 (예: 'CHALLENGING', 'COMPLETE', 'FAILED')
  content   String? // 인증 내용이나 소감 (선택사항)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 관계 설정 (DB 외래키)
  user    User    @relation(fields: [userId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])

  @@map("user_mission") // 실제 DB 테이블 이름
}
